<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SVPS Login Menu</title>
    <link rel="stylesheet" href="/base.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        .card {
            background: linear-gradient(145deg, #0d0d0d, #1a1400);
            border: 1px solid #8a6a00;
            box-shadow: 0 0 30px rgba(180, 140, 0, 0.15), 0 0 60px rgba(180, 140, 0, 0.05);
        }
        .input-box {
            background-color: #111111;
            border: 1px solid #5a4500;
            transition: border-color 0.3s;
        }
        .input-box:focus-within {
            border-color: #c9a000;
            box-shadow: 0 0 8px rgba(201, 160, 0, 0.3);
        }
        .input-box input {
            background-color: #111111;
            color: #f0f0f0;
        }
        .input-box input::placeholder {
            color: #5a4d2a;
        }
        .btn-gold {
            background: linear-gradient(135deg, #c9a000, #8a6a00);
            color: #0d0d0d;
            font-weight: 700;
            letter-spacing: 0.5px;
            transition: all 0.3s;
        }
        .btn-gold:hover {
            background: linear-gradient(135deg, #e0b800, #a07800);
            box-shadow: 0 0 12px rgba(201, 160, 0, 0.4);
        }
        .divider {
            border-color: #2a2000;
        }
        h1 {
            background: linear-gradient(90deg, #c9a000, #ffe066, #c9a000);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
        }
    </style>
</head>
<body class="bg-transparent">
    <div class="w-screen h-screen flex justify-center items-center">
        <div class="card p-6 text-[#eeeeee] min-w-[50vw] rounded-xl">
            <h1 class="text-center text-2xl font-bold mb-1"><%= cnf.name %> Menu</h1>
            <hr class="divider mb-3">
            <p class="text-sm mb-4" style="color:#7a6030">You are now entering the login page of this server. Please enter your <span style="color:#c9a000" class="font-semibold">GrowID</span> and <span style="color:#c9a000" class="font-semibold">Password</span> if you already have an account, or log in as a guest.</p>
            <button type="button"
                class="btn btn-primary hidden"
                data-toggle="modal"
                id="modalButton"
                data-target="#modalShow"
                data-backdrop="static"
                data-keyboard="false"
                hidden
            ></button>
            <form
            action="/player/growid/login/validate" accept-charset="UTF-8"
            role="form"
            required="required"
            autocomplete="off" method="post" class="mt-3">
                <div class="mb-3">
                    <input
                        name="_token"
                        type="hidden"
                        value=""
                    />
                    <label for="loginGrowId" class="block text-sm mb-1" style="color:#9a7a20">GrowID</label>
                    <div class="input-box flex items-center rounded-lg px-3 py-2 gap-2">
                        <i class="fas fa-user text-sm" style="color:#c9a000"></i>
                        <input type="text" name="growId" id="loginGrowId" class="w-full text-sm focus:outline-none" placeholder="Enter your GrowID" required>
                    </div>
                </div>
                <div class="mb-8">
                    <label for="loginPassword" class="block text-sm mb-1" style="color:#9a7a20">Password</label>
                    <div class="input-box flex items-center rounded-lg px-3 py-2 gap-2">
                        <i class="fas fa-lock text-sm" style="color:#c9a000"></i>
                        <input type="password" name="password" id="loginPassword" class="w-full text-sm focus:outline-none" placeholder="Enter your Password" required>
                        <button type="button" id="toggleLogPassword" class="focus:outline-none text-xs" style="color:#c9a000">
                            <i class="fas fa-eye-slash"></i>
                        </button>
                    </div>
                </div>
                <div class="flex flex-col md:flex-row gap-2">
                    <button id="loginButton" type="submit" class="btn-gold px-3 py-2 rounded-lg text-base w-full">Login</button>
                    <button id="regisButton" type="button" class="btn-gold px-3 py-2 rounded-lg text-base w-full">Create New GrowID</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const growId = document.getElementById("loginGrowId");
        const password = document.getElementById("loginPassword");
        const form = document.querySelector("form");
        
        document.getElementById('toggleLogPassword').addEventListener('click', function () {
            const LpasswordField = document.getElementById('loginPassword')
            const LpasswordFieldType = LpasswordField.getAttribute('type');
            if (LpasswordFieldType === 'password') {
                LpasswordField.setAttribute('type', 'text');
                this.innerHTML = '<i class="fas fa-eye"></i>';
            } else {
                LpasswordField.setAttribute('type', 'password');
                this.innerHTML = '<i class="fas fa-eye-slash"></i>';
            }
        });
    
        document.getElementById("regisButton").addEventListener("click", function () {
            const token = btoa(`_token=NONE&growId=&password=`);
            window.location.href = "/player/growid/login/validate?data=" + encodeURIComponent(token);
        });

        form.addEventListener("submit", async (e) => {
            e.preventDefault();
            const token = btoa(`_token=NONE&growId=${growId.value}&password=${password.value}`);
            window.location.href = "/player/growid/login/validate?data=" + encodeURIComponent(token);
        });
    </script>
</body>
</html>
