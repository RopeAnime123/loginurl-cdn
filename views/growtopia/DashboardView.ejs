<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SV-Private-Server Login</title>
    <link rel="stylesheet" href="/base.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700;900&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold-100: #ffe9a0;
            --gold-200: #ffd760;
            --gold-300: #e6b800;
            --gold-400: #c9a000;
            --gold-500: #a07800;
            --gold-600: #8a6a00;
            --gold-700: #5a4500;
            --gold-800: #3a2d00;
            --dark-100: #1a1a1a;
            --dark-200: #141414;
            --dark-300: #0f0f0f;
            --dark-400: #0a0a0a;
            --dark-500: #050505;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Jost', sans-serif;
            background: var(--dark-500);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            position: relative;
        }

        /* ── Animated background ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse 600px 400px at 20% 20%, rgba(201,160,0,0.06), transparent),
                radial-gradient(ellipse 500px 500px at 80% 80%, rgba(201,160,0,0.04), transparent),
                radial-gradient(ellipse 300px 300px at 50% 50%, rgba(201,160,0,0.02), transparent);
            animation: bgPulse 8s ease-in-out infinite alternate;
            z-index: 0;
        }

        @keyframes bgPulse {
            0% { opacity: 0.6; }
            100% { opacity: 1; }
        }

        /* ── Floating gold particles ── */
        .particle {
            position: fixed;
            width: 2px;
            height: 2px;
            background: var(--gold-400);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
        }

        .particle:nth-child(1) { top: 15%; left: 10%; animation: float 6s ease-in-out infinite; opacity: 0.3; }
        .particle:nth-child(2) { top: 70%; left: 85%; animation: float 8s ease-in-out infinite 1s; opacity: 0.2; width: 3px; height: 3px; }
        .particle:nth-child(3) { top: 40%; left: 70%; animation: float 7s ease-in-out infinite 2s; opacity: 0.25; }
        .particle:nth-child(4) { top: 80%; left: 25%; animation: float 9s ease-in-out infinite 0.5s; opacity: 0.15; width: 4px; height: 4px; }
        .particle:nth-child(5) { top: 25%; left: 55%; animation: float 5s ease-in-out infinite 3s; opacity: 0.2; }
        .particle:nth-child(6) { top: 60%; left: 40%; animation: float 10s ease-in-out infinite 1.5s; opacity: 0.1; width: 3px; height: 3px; }

        @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); }
            25% { transform: translateY(-20px) translateX(10px); }
            50% { transform: translateY(-10px) translateX(-15px); }
            75% { transform: translateY(-25px) translateX(5px); }
        }

        /* ── Card ── */
        .login-card {
            position: relative;
            z-index: 1;
            width: 90vw;
            max-width: 440px;
            background: linear-gradient(160deg, #111108 0%, #0a0a06 40%, #0d0b02 100%);
            border: 1px solid var(--gold-700);
            border-radius: 16px;
            padding: 40px 36px;
            box-shadow:
                0 0 60px rgba(201,160,0,0.06),
                0 0 120px rgba(201,160,0,0.03),
                inset 0 1px 0 rgba(201,160,0,0.08);
            animation: cardEntry 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            opacity: 0;
            transform: translateY(30px);
        }

        @keyframes cardEntry {
            to { opacity: 1; transform: translateY(0); }
        }

        /* ── Gold corner accents ── */
        .login-card::before,
        .login-card::after {
            content: '';
            position: absolute;
            width: 40px;
            height: 40px;
            border-color: var(--gold-600);
            border-style: solid;
            pointer-events: none;
            opacity: 0.5;
        }

        .login-card::before {
            top: 10px;
            left: 10px;
            border-width: 1px 0 0 1px;
            border-radius: 4px 0 0 0;
        }

        .login-card::after {
            bottom: 10px;
            right: 10px;
            border-width: 0 1px 1px 0;
            border-radius: 0 0 4px 0;
        }

        /* ── Title ── */
        .title-section {
            text-align: center;
            margin-bottom: 8px;
            animation: fadeIn 0.8s 0.3s backwards;
        }

        .server-badge {
            display: inline-block;
            font-family: 'Jost', sans-serif;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: var(--gold-500);
            background: rgba(201,160,0,0.06);
            border: 1px solid rgba(201,160,0,0.12);
            padding: 4px 14px;
            border-radius: 20px;
            margin-bottom: 16px;
        }

        .title {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            font-size: 26px;
            background: linear-gradient(135deg, var(--gold-200), var(--gold-400), var(--gold-200));
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 4s ease-in-out infinite;
            letter-spacing: 2px;
        }

        @keyframes shimmer {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .title-sub {
            font-family: 'Jost', sans-serif;
            font-size: 12px;
            font-weight: 400;
            letter-spacing: 4px;
            text-transform: uppercase;
            color: var(--gold-700);
            margin-top: 6px;
        }

        /* ── Divider ── */
        .divider {
            border: none;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--gold-700), var(--gold-600), var(--gold-700), transparent);
            margin: 20px 0;
            animation: fadeIn 0.8s 0.4s backwards;
        }

        /* ── Subtitle ── */
        .subtitle {
            font-size: 13px;
            line-height: 1.6;
            color: #6a5d3a;
            text-align: center;
            margin-bottom: 28px;
            animation: fadeIn 0.8s 0.5s backwards;
        }

        .subtitle .hl {
            color: var(--gold-400);
            font-weight: 600;
        }

        /* ── Form ── */
        .form-group {
            margin-bottom: 20px;
        }

        .form-group:nth-child(1) { animation: fadeIn 0.6s 0.5s backwards; }
        .form-group:nth-child(2) { animation: fadeIn 0.6s 0.6s backwards; }

        .form-label {
            display: block;
            font-size: 11px;
            font-weight: 500;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--gold-600);
            margin-bottom: 8px;
        }

        .input-wrapper {
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--dark-300);
            border: 1px solid rgba(201,160,0,0.12);
            border-radius: 10px;
            padding: 0 16px;
            height: 48px;
            transition: all 0.3s ease;
        }

        .input-wrapper:focus-within {
            border-color: var(--gold-500);
            box-shadow: 0 0 20px rgba(201,160,0,0.08), inset 0 0 20px rgba(201,160,0,0.02);
        }

        .input-wrapper i {
            color: var(--gold-700);
            font-size: 14px;
            transition: color 0.3s;
        }

        .input-wrapper:focus-within i {
            color: var(--gold-400);
        }

        .input-wrapper input {
            flex: 1;
            background: transparent;
            border: none;
            outline: none;
            font-family: 'Jost', sans-serif;
            font-size: 14px;
            font-weight: 400;
            color: #e8e0c8;
            letter-spacing: 0.3px;
        }

        .input-wrapper input::placeholder {
            color: #3d3520;
            font-weight: 300;
        }

        .toggle-pass {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--gold-700);
            font-size: 13px;
            padding: 4px;
            transition: color 0.3s;
        }

        .toggle-pass:hover {
            color: var(--gold-400);
        }

        /* ── Buttons ── */
        .btn-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 28px;
            animation: fadeIn 0.6s 0.7s backwards;
        }

        .btn {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            height: 48px;
            border-radius: 10px;
            font-family: 'Jost', sans-serif;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.8px;
            text-transform: uppercase;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
            overflow: hidden;
        }

        .btn-login {
            background: linear-gradient(135deg, var(--gold-300), var(--gold-500));
            color: var(--dark-500);
            box-shadow: 0 4px 20px rgba(201,160,0,0.2);
        }

        .btn-login:hover {
            background: linear-gradient(135deg, var(--gold-200), var(--gold-400));
            box-shadow: 0 4px 30px rgba(201,160,0,0.3);
            transform: translateY(-1px);
        }

        .btn-login:active {
            transform: translateY(0);
            box-shadow: 0 2px 10px rgba(201,160,0,0.2);
        }

        /* Shine effect on login button */
        .btn-login::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -60%;
            width: 40%;
            height: 200%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
            transform: skewX(-20deg);
            animation: btnShine 4s ease-in-out infinite;
        }

        @keyframes btnShine {
            0%, 100% { left: -60%; }
            50% { left: 120%; }
        }

        .btn-register {
            background: transparent;
            color: var(--gold-500);
            border: 1px solid rgba(201,160,0,0.2);
        }

        .btn-register:hover {
            border-color: var(--gold-500);
            background: rgba(201,160,0,0.04);
            color: var(--gold-300);
            transform: translateY(-1px);
        }

        .btn-register:active {
            transform: translateY(0);
        }

        /* ── Footer ── */
        .footer {
            text-align: center;
            margin-top: 24px;
            font-size: 11px;
            color: #2a2410;
            letter-spacing: 1px;
            animation: fadeIn 0.6s 0.8s backwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ── Error toast ── */
        .toast {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%) translateY(-80px);
            background: linear-gradient(135deg, #1a1000, #0d0800);
            border: 1px solid rgba(255, 80, 80, 0.3);
            color: #ff8080;
            padding: 12px 24px;
            border-radius: 10px;
            font-family: 'Jost', sans-serif;
            font-size: 13px;
            z-index: 100;
            opacity: 0;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
            pointer-events: none;
        }

        .toast.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }

        /* ── Responsive ── */
        @media (max-width: 480px) {
            .login-card {
                padding: 32px 24px;
                border-radius: 12px;
            }
            .title {
                font-size: 22px;
            }
        }

        @media (min-width: 768px) {
            .btn-group {
                flex-direction: row;
            }
            .btn {
                flex: 1;
            }
        }
    </style>
</head>
<body>
    <!-- Background particles -->
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>

    <!-- Toast for validation -->
    <div class="toast" id="toast"></div>

    <div class="login-card">
        <!-- Corner decorations handled by ::before and ::after -->

        <div class="title-section">
            <div class="server-badge">SV Private Server</div>
            <h1 class="title">SV-Private-Server</h1>
            <p class="title-sub">Login Page</p>
        </div>

        <hr class="divider">

        <p class="subtitle">
            Enter your <span class="hl">GrowID</span> and <span class="hl">Password</span> to continue,<br>
            or create a new account below.
        </p>

        <form id="loginForm" action="/player/growid/login/validate" method="post" autocomplete="off">
            <input name="_token" type="hidden" value="">

            <div class="form-group">
                <label for="loginGrowId" class="form-label">GrowID</label>
                <div class="input-wrapper">
                    <i class="fas fa-user"></i>
                    <input type="text" name="growId" id="loginGrowId" placeholder="Enter your GrowID" required>
                </div>
            </div>

            <div class="form-group">
                <label for="loginPassword" class="form-label">Password</label>
                <div class="input-wrapper">
                    <i class="fas fa-lock"></i>
                    <input type="password" name="password" id="loginPassword" placeholder="Enter your Password" required>
                    <button type="button" id="togglePassword" class="toggle-pass" aria-label="Toggle password visibility">
                        <i class="fas fa-eye-slash"></i>
                    </button>
                </div>
            </div>

            <div class="btn-group">
                <button id="loginButton" type="submit" class="btn btn-login">
                    <i class="fas fa-sign-in-alt"></i> Login
                </button>
                <button id="regisButton" type="button" class="btn btn-register">
                    <i class="fas fa-user-plus"></i> Register
                </button>
            </div>
        </form>

        <div class="footer">SECURE LOGIN</div>
    </div>

    <script>
        const growId = document.getElementById('loginGrowId');
        const password = document.getElementById('loginPassword');
        const form = document.getElementById('loginForm');
        const toast = document.getElementById('toast');

        function showToast(msg) {
            toast.textContent = msg;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 3000);
        }

        // Toggle password visibility
        document.getElementById('togglePassword').addEventListener('click', function () {
            const isPassword = password.type === 'password';
            password.type = isPassword ? 'text' : 'password';
            this.innerHTML = isPassword
                ? '<i class="fas fa-eye"></i>'
                : '<i class="fas fa-eye-slash"></i>';
        });

        // Register → redirect with empty credentials
        document.getElementById('regisButton').addEventListener('click', function () {
            const token = btoa('_token=NONE&growId=&password=');
            window.location.href = '/player/growid/login/validate?data=' + encodeURIComponent(token);
        });

        // Login → validate then redirect
        form.addEventListener('submit', function (e) {
            e.preventDefault();

            const id = growId.value.trim();
            const pw = password.value.trim();

            if (!id) {
                showToast('Please enter your GrowID.');
                growId.focus();
                return;
            }
            if (!pw) {
                showToast('Please enter your password.');
                password.focus();
                return;
            }

            const token = btoa('_token=NONE&growId=' + id + '&password=' + pw);
            window.location.href = '/player/growid/login/validate?data=' + encodeURIComponent(token);
        });
    </script>
</body>
</html>
